# ============================================================
# Solvio — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs réelles.
# Ne jamais committer le fichier .env (il est dans .gitignore).
# ============================================================

# --- Supabase ---
# Disponible dans : Supabase Dashboard > Project Settings > API

# URL du projet Supabase (ex: https://xxxx.supabase.co)
VITE_SUPABASE_URL=

# Clé publique anon (safe côté client, utilisée par supabase-js)
VITE_SUPABASE_PUBLISHABLE_KEY=

# ID du projet Supabase (utilisé par la CLI Supabase pour les migrations)
VITE_SUPABASE_PROJECT_ID=

# --- Edge Functions (serveur uniquement, NE PAS mettre en VITE_) ---
# Ces variables sont configurées directement dans Supabase Dashboard
# > Edge Functions > Secrets. Ne pas les mettre dans .env local.
#
# SUPABASE_SERVICE_ROLE_KEY=   # clé admin, utilisée par execute-dca
# CRON_SECRET=                 # token Bearer pour scheduled-snapshots et execute-dca
